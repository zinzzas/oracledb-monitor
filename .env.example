# Oracle 접속 정보 (클라이언트 접속 - 리스너로만 연결, python-oracledb Thin mode)
ORACLE_USER=SYSTEM
ORACLE_PASSWORD=SYSTEM
# host:port/service_name 형식. RAC/SCAN이면 scan주소:port/service
ORACLE_DSN=localhost:1521/ORCLCDB

# 수집 주기 (초)
POLL_INTERVAL_SEC=5

# 슬로우 쿼리 판단 기준 (평균 elapsed, 초)
SLOW_QUERY_THRESHOLD_SEC=5

# SQLite 저장 파일 경로 (프로젝트 루트 기준)
SQLITE_PATH=./data/monitor.db

# 히스토리 보관 기간 (시간) - 이보다 오래된 스냅샷은 정리
RETENTION_HOURS=24

# 대시보드에 표시될 인스턴스 라벨 (MaxGauge의 "PROD11P" 같은 표시명)
INSTANCE_LABEL=ORCLCDB
